{
  "permissions": {
    "allow": []
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "if": "Bash(git *)",
            "command": "bash \"$CLAUDE_PROJECT_DIR/.claude/hooks/check-git-branch.sh\"",
            "timeout": 10
          }
        ]
      }
    ]
  }
}
